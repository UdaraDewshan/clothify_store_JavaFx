<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardFormController">
    <children>
        <AnchorPane prefHeight="700.0" prefWidth="250.0" style="-fx-background-color: #1a1d2b;">
            <children>
                <Label layoutX="60.0" layoutY="35.0" text="CLOTHIFY" textFill="WHITE">
                    <font>
                        <Font name="Arial Rounded MT Bold" size="26.0" />
                    </font>
                </Label>

                <VBox layoutY="120.0" prefHeight="400.0" prefWidth="250.0" spacing="10.0">
                    <children>
                        <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#btnDashboardOnAction" prefHeight="55.0" prefWidth="250.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 40; -fx-cursor: hand;" text="Dashboard">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Button>

                        <Button fx:id="btnPOS" mnemonicParsing="false" onAction="#btnPOSOnAction" prefHeight="55.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #a0aabf; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 40; -fx-cursor: hand;" text="Point of Sale">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Button>

                        <Button fx:id="btnInventory" mnemonicParsing="false" onAction="#btnInventoryOnAction" prefHeight="55.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #a0aabf; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 40; -fx-cursor: hand;" text="Inventory">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Button>

                        <Button fx:id="btnSuppliers" mnemonicParsing="false" onAction="#btnSuppliersOnAction" prefHeight="55.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #a0aabf; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 40; -fx-cursor: hand;" text="Suppliers">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Button>

                        <Button fx:id="btnEmployees" mnemonicParsing="false" onAction="#btnEmployeesOnAction" prefHeight="55.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #a0aabf; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 40; -fx-cursor: hand;" text="Employees">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Button>

                        <Button fx:id="btnReports" mnemonicParsing="false" onAction="#btnReportsOnAction" prefHeight="55.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #a0aabf; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 40; -fx-cursor: hand;" text="Reports">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Button>
                    </children>
                </VBox>

                <Button layoutX="40.0" layoutY="620.0" mnemonicParsing="false" onAction="#btnLogoutOnAction" prefHeight="40.0" prefWidth="170.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;" text="Logout">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </AnchorPane>

        <AnchorPane fx:id="contentArea" layoutX="250.0" prefHeight="700.0" prefWidth="950.0" style="-fx-background-color: #f4f5f9;">
            <children>
                <Label layoutX="320.0" layoutY="320.0" text="Welcome to Dashboard!" textFill="#7d8597">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>