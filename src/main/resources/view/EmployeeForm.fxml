<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="700.0" prefWidth="950.0" style="-fx-background-color: #f4f5f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.EmployeeFormController">

    <Text fill="#3b82f6" layoutX="50.0" layoutY="55.0" text="Employee Management">
        <font>
            <Font name="Berlin Sans FB Demi Bold" size="28.0" />
        </font>
    </Text>

    <Rectangle arcHeight="30" arcWidth="30" fill="WHITE" height="280.0" layoutX="50" layoutY="80" stroke="#e0e0e0" strokeType="INSIDE" width="850.0" />

    <Label layoutX="80" layoutY="110" text="Full Name" textFill="#5a5c6e">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>
    <TextField fx:id="txtName" layoutX="170" layoutY="105" prefWidth="250" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;" />

    <Label layoutX="80" layoutY="160" text="Email (User)" textFill="#5a5c6e">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>
    <TextField fx:id="txtEmail" layoutX="170" layoutY="155" prefWidth="250" promptText="name@clothify.com" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;" />

    <Label layoutX="80" layoutY="210" text="Password" textFill="#5a5c6e">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>
    <TextField fx:id="txtPassword" layoutX="170" layoutY="205" prefWidth="250" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;" />

    <Label layoutX="80" layoutY="260" text="Role" textFill="#5a5c6e">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>
    <ComboBox fx:id="cmbRole" layoutX="170" layoutY="255" prefWidth="250" style="-fx-padding: 5; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5; -fx-background-color: white;" />

    <Label layoutX="470" layoutY="110" text="Phone No" textFill="#5a5c6e">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>
    <TextField fx:id="txtPhone" layoutX="560" layoutY="105" prefWidth="250" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;" />

    <Label layoutX="470" layoutY="160" text="Address" textFill="#5a5c6e">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>
    <TextField fx:id="txtAddress" layoutX="560" layoutY="155" prefWidth="250" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;" />

    <Label layoutX="470" layoutY="210" text="Join Date" textFill="#5a5c6e">
        <font><Font name="System Bold" size="14.0" /></font>
    </Label>
    <TextField fx:id="txtJoinDate" layoutX="560" layoutY="205" prefWidth="250" promptText="YYYY-MM-DD" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;" />

    <TextField fx:id="txtHiddenId" visible="false" />

    <Button layoutX="430.0" layoutY="300.0" onAction="#btnClearOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Clear">
        <font><Font name="System Bold" size="14.0" /></font>
    </Button>
    <Button layoutX="520.0" layoutY="300.0" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Delete">
        <font><Font name="System Bold" size="14.0" /></font>
    </Button>
    <Button layoutX="610.0" layoutY="300.0" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Update">
        <font><Font name="System Bold" size="14.0" /></font>
    </Button>
    <Button layoutX="700.0" layoutY="300.0" onAction="#btnAddOnAction" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Add Employee">
        <font><Font name="System Bold" size="14.0" /></font>
    </Button>

    <Label fx:id="lblStatus" layoutX="50.0" layoutY="370.0" text="" textFill="RED" />

    <TableView fx:id="tblEmployees" layoutX="50.0" layoutY="395.0" prefHeight="275.0" prefWidth="850.0" style="-fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colName" prefWidth="180.0" text="Name" />
            <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email (Username)" />
            <TableColumn fx:id="colRole" prefWidth="90.0" text="Role" />
            <TableColumn fx:id="colPhone" prefWidth="120.0" text="Phone No" />
            <TableColumn fx:id="colDate" prefWidth="100.0" text="Join Date" />
        </columns>
    </TableView>

</AnchorPane>